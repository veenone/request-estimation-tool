# Git
.git
.gitignore

# IDE and editor artefacts
.vscode
.idea
*.swp
*.swo

# Python build / cache artefacts
__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache
*.egg-info
dist
build

# Runtime database (created inside the container at runtime)
data/estimation.db

# Desktop frontend (not needed in the Docker image)
frontend_desktop/

# Documentation (keep SPEC.md, drop everything else)
*.md
!SPEC.md
SPEC.docx

# TLS certificates (mounted at runtime, not baked into image)
certs/

# Environment files (never bake secrets into the image)
.env
.env.*
